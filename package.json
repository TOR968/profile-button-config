{
  "scripts": {
    "sync-manifest": "npx tsx scripts/sync-manifest.ts",
    "dev": "npm run sync-manifest && millennium-ttc --build dev",
    "watch": "npm run sync-manifest && nodemon --watch webkit --watch frontend --watch config --ext ts,tsx,js,jsx --exec \"millennium-ttc --build dev\"",
    "build": "npm run sync-manifest && millennium-ttc --build prod",
    "sync-version": "npx tsx scripts/sync-version.ts 1.0.0",
    "release": "npx tsx scripts/build-plugin.ts 1.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@steambrew/ttc": "^3.3.7",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "archiver": "^7.0.1",
    "nodemon": "^3.1.14",
    "semantic-release": "^25.0.6",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  },
  "type": "module",
  "name": "profile-button-config",
  "version": "1.0.1",
  "description": "A Millennium plugin that adds buttons to Steam community profile pages.",
  "main": "./frontend/index.tsx",
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@steambrew/client": "^5.8.5",
    "@steambrew/webkit": "^5.8.4",
    "react": "^19.2.7"
  }
}
